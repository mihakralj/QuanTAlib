<?xml version="1.0" encoding="utf-8"?>
<!-- NDepend coverage exclusion file -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="Code Coverage">
        <Configuration>
          <CodeCoverage>
            <Functions>
              <!-- Exclude explicit interface implementations that cause NDepend mismatch warnings -->
              <Exclude>
                <Function>.*::System\.Collections\..*\.GetEnumerator\(\).*</Function>
              </Exclude>
            </Functions>
          </CodeCoverage>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
